# Copy this file to `.env` and fill in your own values.
# The real `.env` is gitignored — your secrets stay on your machine.

# REQUIRED: get a free Gemini API key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OPTIONAL: override the Gemini model (default is gemini-2.5-flash-lite — cheap + fast)
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-pro

# OPTIONAL: SMTP for Agent 3's "email me daily deals" feature
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=you@example.com
